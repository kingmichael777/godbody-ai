# ─── Server ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── HeyGen ──────────────────────────────────────────────
HEYGEN_API_KEY=your_heygen_api_key_here

# ─── Replicate ────────────────────────────────────────────
REPLICATE_API_KEY=your_replicate_api_key_here

# ─── ElevenLabs ──────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ─── Stripe ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (create in Stripe dashboard)
STRIPE_PRICE_STARTER=price_xxx_starter
STRIPE_PRICE_CREATOR=price_xxx_creator
STRIPE_PRICE_PRO=price_xxx_pro
STRIPE_PRICE_UNLIMITED=price_xxx_unlimited

# ─── AWS / Cloudflare R2 (optional - dev uses local disk) ─
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=auto
AWS_S3_BUCKET=noor-ai-uploads
# For Cloudflare R2, set this to your R2 endpoint:
# AWS_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
